# Path to the servers YAML config.
CONFIG_FILE=servers.yaml

# HTTP bind address for /metrics.
BIND=:8080

# --- Cloudflare Queues producer (optional) ---

# Master switch: set to "true" to enable the periodic ping + queue push loop.
# When false (default) only the scrape-triggered Prometheus path runs.
QUEUE_ENABLED=false

# How often to ping all servers and push a PingBatch to the queue.
# Accepts any Go duration (e.g. 15s, 30s, 1m).
PING_INTERVAL=30s

# Value written into PingBatch.source. Used to identify the producer
# (e.g. region or deployment name) on the consumer side.
QUEUE_SOURCE=primary

# Cloudflare credentials. The token needs Queues:Edit on the target queue.
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_QUEUE_ID=

# Directory used to persist batches when the Cloudflare API is unreachable.
# Files drain oldest-first after the next successful push.
SPOOL_DIR=./spool

# Maximum spooled batches replayed per successful tick.
SPOOL_DRAIN_PER_TICK=5
